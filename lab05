**// Leaflet Tutorial 1 //** 

<!DOCTYPE html>
<html>
<head>
  <title>Leaflet Quick Start</title>

  <!-- Leaflet CSS -->
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />

  <style>
    #map {height: 500px;}
  </style>
</head>

<body>
  <h2>Leaflet Quick Start — Completed Tutorial</h2>
  <div id="map"></div>

  <!-- Leaflet JS -->
  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
  ></script>

  <script>
    // 1. Initialize the map
    var map = L.map("map").setView([51.505, -0.09], 13);

    // 2. Add OpenStreetMap tile layer
    L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 19,
      attribution:
        '&copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    }).addTo(map);

    // 3. Add a marker
    var marker = L.marker([51.5, -0.09]).addTo(map);

    // 4. Add a circle
    var circle = L.circle([51.508, -0.11], {
      color: "red",
      fillColor: "#f03",
      fillOpacity: 0.5,
      radius: 500,
    }).addTo(map);

    // 5. Add a polygon
    var polygon = L.polygon([
      [51.509, -0.08],
      [51.503, -0.06],
      [51.51, -0.047],
    ]).addTo(map);

    // 6. Bind popups
    marker.bindPopup("<b>Hello world!</b><br>I am a popup.").openPopup();
    circle.bindPopup("I am a circle.");
    polygon.bindPopup("I am a polygon.");

    // 7. Standalone popup on click
    var popup = L.popup();

    function onMapClick(e) {
      popup
        .setLatLng(e.latlng)
        .setContent("You clicked the map at " + e.latlng.toString())
        .openOn(map);
    }

    map.on("click", onMapClick);
  </script>
</body>
</html>

**// Leaflet Tutorial 2 //** 

<!DOCTYPE html>
<html>
<head>
  <title>Leaflet Mobile Tutorial — Completed</title>

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />

  <style>
    body {
      margin: 0;
      padding: 0;
    }

    #map {
      height: 100vh; /* Full mobile height */
      width: 100vw;
    }

    /* Optional: hide attribution on very small screens */
    @media (max-width: 480px) {
      .leaflet-control-attribution {
        font-size: 10px;
      }
    }
  </style>
</head>

<body>
  <div id="map"></div>

  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
  ></script>

  <script>
    // Detect mobile browser
    var isMobile = /Android|iPhone|iPad|iPod/i.test(navigator.userAgent);

    // Initialize map with mobile-friendly options
    var map = L.map("map", {
      zoomControl: !isMobile, // hide zoom buttons on mobile
      tap: isMobile ? false : true // disable tap delay on mobile
    }).setView([51.505, -0.09], 13);

    // Add tile layer
    L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 19,
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
    }).addTo(map);

    // Add a marker
    L.marker([51.5, -0.09])
      .addTo(map)
      .bindPopup("Mobile-friendly Leaflet map!")
      .openPopup();

    // Add geolocation button
    function locateUser() {
      map.locate({ setView: true, maxZoom: 16 });
    }

    // Add a simple control button
    L.control
      .custom({
        position: "topright",
        content:
          '<button style="background:white;padding:6px;border-radius:4px;border:1px solid #ccc;">📍 Locate Me</button>',
        events: {
          click: function () {
            locateUser();
          }
        }
      })
      .addTo(map);

    // Handle geolocation found
    map.on("locationfound", function (e) {
      L.circle(e.latlng, {
        radius: e.accuracy,
        color: "blue",
        fillColor: "#30f",
        fillOpacity: 0.3
      }).addTo(map);

      L.marker(e.latlng)
        .addTo(map)
        .bindPopup("You are here!")
        .openPopup();
    });

    // Handle geolocation error
    map.on("locationerror", function () {
      alert("Unable to retrieve your location.");
    });

    // Add tap-to-popup for mobile
    map.on("click", function (e) {
      L.popup()
        .setLatLng(e.latlng)
        .setContent("You tapped at " + e.latlng.toString())
        .openOn(map);
    });

    // Add zoom control manually for desktop
    if (!isMobile) {
      L.control.zoom({ position: "topright" }).addTo(map);
    }

    // Custom control extension
    L.Control.Custom = L.Control.extend({
      options: {
        position: "topright"
      },
      initialize: function (options) {
        L.Util.setOptions(this, options);
      },
      onAdd: function () {
        var container = L.DomUtil.create("div");
        container.innerHTML = this.options.content;
        if (this.options.events) {
          for (var event in this.options.events) {
            container.addEventListener(event, this.options.events[event]);
          }
        }
        return container;
      }
    });

    L.control.custom = function (opts) {
      return new L.Control.Custom(opts);
    };
  </script>
</body>
</html>

