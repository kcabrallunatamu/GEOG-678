<!DOCTYPE html>
<html>
<head>
    <title>Kassandra's First Web Map</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
     integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
     crossorigin=""/>
    
    <style>
        html, body {
            height: 100%;
            margin: 0;
        }
        #map {
            width: 100%;
            height: 100%;
        }
    </style>
</head>

<body>
    <div id="map"></div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
     integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
     crossorigin=""></script>

    <script>
        // Initialize the map
        var map = L.map('map').fitWorld();
        
        // Add OpenStreetMap tiles
        L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);
        
        // TAMU landmark coordinates
        var kyleField = [30.6084, -96.3402];
        var omBuilding = [30.6179, -96.3386];
        var academicBuilding = [30.6159, -96.3413];
        
        // ✔ Requirement: Zoom to detected location
        map.locate({ setView: true, maxZoom: 16 });
        
        function onLocationFound(e) {
            var radius = e.accuracy / 2;

            L.marker(e.latlng)
                .addTo(map)
                .bindPopup("You are within " + radius.toFixed(1) + " meters of this point")
                .openPopup();

            L.circle(e.latlng, radius).addTo(map);
        }

        function onLocationError(e) {
            map.setView(kyleField, 15);
            alert("Location unavailable. Centering map on Kyle Field.");
        }

        // ✔ Requirement: Circle around Kyle Field
        L.circle(kyleField, {
            radius: 200,
            color: "maroon",
            fillColor: "#500000",
            fillOpacity: 0.4
        })
        .addTo(map)
        .bindPopup("Kyle Field — Home of the Fightin' Texas Aggies!");

        // ✔ Requirement: Custom icons for O&M and Academic Building
        var tamuIcon = L.icon({
            iconUrl: "https://upload.wikimedia.org/wikipedia/commons/5/5b/TAM-Logo.png",
            iconSize: [40, 40],
            iconAnchor: [20, 40],
            popupAnchor: [0, -35]
        });

        L.marker(omBuilding, { icon: tamuIcon })
            .addTo(map)
            .bindPopup("O&M Building — Department of Geology & Geophysics");

        L.marker(academicBuilding, { icon: tamuIcon })
            .addTo(map)
            .bindPopup("Academic Building — A&M Landmark Since 1914");

        // ✔ Requirement: Click event to show coordinates
        map.on("click", function(e) {
            L.popup()
                .setLatLng(e.latlng)
                .setContent(
                    "Coordinates:<br>" +
                    e.latlng.lat.toFixed(5) + ", " +
                    e.latlng.lng.toFixed(5)
                )
                .openOn(map);
        });

        // Register event handlers
        map.on('locationfound', onLocationFound);
        map.on('locationerror', onLocationError);
    </script>
</body>
</html>


