// Task 4: Functions to compute bounding box corners


// Top Left = Max Lat, Min Lon
function findTopLeft(points) {
    let best = points[0];

    for (let p of points) {
        if (p.lat > best.lat || (p.lat === best.lat && p.lon < best.lon)) {
            best = p;
        }
    }
    return best;
}

// Top Right = Max Lat, Max Lon
function findTopRight(points) {
    let best = points[0];

    for (let p of points) {
        if (p.lat > best.lat || (p.lat === best.lat && p.lon > best.lon)) {
            best = p;
        }
    }
    return best;
}

// Bottom Left = Min Lat, Min Lon
function findBottomLeft(points) {
    let best = points[0];

    for (let p of points) {
        if (p.lat < best.lat || (p.lat === best.lat && p.lon < best.lon)) {
            best = p;
        }
    }
    return best;
}

// Bottom Right = Min Lat, Max Lon
function findBottomRight(points) {
    let best = points[0];

    for (let p of points) {
        if (p.lat < best.lat || (p.lat === best.lat && p.lon > best.lon)) {
            best = p;
        }
    }
    return best;
}
